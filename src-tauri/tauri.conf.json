{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shadowsocksr-client-linux",
  "version": "0.5.0",
  "identifier": "com.liangzhaoyuan12.shadowsocksr-client-linux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "shadowsocksr-client-linux",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb","rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ssr-native-client"
    ],
    "category": "Utility"
  }
}
